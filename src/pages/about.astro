---
import "~/styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About · SG Long-Weekend Optimizer</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <main class="mx-auto max-w-prose p-6">
      <h1 class="text-2xl font-bold">About</h1>
      <p class="mt-4">
        SG Long-Weekend Optimizer takes your annual leave balance and a year,
        and returns a ranked list of leave-taking strategies that maximise your
        contiguous days off around Singapore's public holidays.
      </p>
      <p class="mt-4">
        Public holiday data comes from
        <a href="https://data.gov.sg" class="underline">data.gov.sg</a>,
        used under the Singapore Open Data Licence.
      </p>
      <p class="mt-4 text-sm text-gray-500">
        Not affiliated with the Government of Singapore.
      </p>
      <p class="mt-6">
        <a href="/" class="underline">← Back to optimizer</a>
      </p>
    </main>
  </body>
</html>
