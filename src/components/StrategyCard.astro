---
import type { Strategy } from "~/lib/types";
import dayjs from "dayjs";

interface Props {
  strategy: Strategy;
}
const { strategy } = Astro.props;

const fmt = (d: string) => dayjs(d).format("ddd D MMM");

// Enumerate every date in the strategy's contiguous range so the hover
// island can light up the whole stretch in the calendar, not just the
// chosen leave days.
const rangeDates: string[] = [];
{
  let d = dayjs(strategy.startDate);
  const end = dayjs(strategy.endDate);
  while (d.isBefore(end) || d.isSame(end)) {
    rangeDates.push(d.format("YYYY-MM-DD"));
    d = d.add(1, "day");
  }
}
---

<li
  class="strategy-card cursor-pointer rounded border p-4 shadow-sm transition hover:border-leave hover:shadow-md"
  data-strategy-id={strategy.id}
  data-strategy-dates={rangeDates.join(",")}
>
  <div class="flex items-baseline justify-between">
    <h3 class="text-lg font-semibold">
      {fmt(strategy.startDate)} – {fmt(strategy.endDate)}
    </h3>
    <span class="rounded bg-leave/10 px-2 py-0.5 text-xs font-medium text-leave">
      {strategy.efficiency.toFixed(1)}x
    </span>
  </div>
  <p class="mt-2 text-sm">
    <span class="text-2xl font-bold">{strategy.totalDaysOff}</span>
    <span class="text-gray-600"> days off · {strategy.leaveDaysUsed} leave</span>
  </p>
  {strategy.holidaysIncluded.length > 0 && (
    <p class="mt-1 text-xs text-gray-500">
      Includes: {strategy.holidaysIncluded.map((h) => h.name).join(", ")}
    </p>
  )}
</li>
